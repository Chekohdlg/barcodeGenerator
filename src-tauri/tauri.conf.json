{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BarcodeGenerator",
  "version": "1.0.0",
  "identifier": "com.barcodegenerator.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BarcodeGenerator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1RDY5NTU1NDE5QkVEMTMKUldRVDdadEJWWlhXNWJiRkovZUU4ZjRqQTZ4WGQ4cXM5anFaMXdrcFZNMzFxaDFOSlB5WHFrWGcK",
      "endpoints": [
        "https://github.com/Chekohdlg/barcodeGenerator/releases/latest/download/latest.json"
      ],
      "windows": {
        "installerArgs": [],
        "installMode": "passive"
      }
    }
  }
}
